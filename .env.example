# =============================================
# FoodLister Application Configuration
# Copy this file to .env.local and fill in real values
# =============================================

# --- Supabase (Required) ---
# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url

# Your Supabase anon/public key (safe for frontend)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Your Supabase service role key (SERVER-SIDE ONLY - never expose to frontend)
# Required for admin API routes that bypass RLS
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Cloudinary (Optional) ---
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- OpenAI (Optional) ---
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key

# --- Push Notifications (Optional) ---
# Generate VAPID keys with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# --- Stripe (Optional) ---
# Create a Stripe account at https://stripe.com and get these from the Dashboard
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# --- App Settings (Optional) ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

